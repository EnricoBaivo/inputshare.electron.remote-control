{
  "appId": "dev.inputshare.client",
  "productName": "InputShare Client",
  "directories": {
    "output": "dist-pack/client"
  },
  "files": [
    "dist/apps/client/**/*",
    "dist/packages/shared/**/*",
    "dist/ui/apps/client/**/*",
    "dist/ui/assets/**/*",
    "packages/shared/dist/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist/apps/client/main.js"
  },
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false
  },
  "asar": true
}
