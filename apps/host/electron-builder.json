{
  "appId": "dev.inputshare.host",
  "productName": "InputShare Host",
  "directories": {
    "output": "dist-pack/host"
  },
  "files": [
    "dist/apps/host/**/*",
    "dist/packages/shared/**/*",
    "dist/ui/apps/host/**/*",
    "dist/ui/assets/**/*",
    "packages/shared/dist/**/*",
    "node_modules/ws/**/*",
    "node_modules/koffi/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "apps/host/lib/ViGEmClient.dll",
      "to": "lib/ViGEmClient.dll"
    }
  ],
  "extraMetadata": {
    "main": "dist/apps/host/main.js"
  },
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false
  },
  "asar": true,
  "asarUnpack": [
    "node_modules/koffi/**/*",
    "**/*.dll"
  ]
}
