{
  "name": "inputshare",
  "version": "2.0.0",
  "private": true,
  "author": "EnricoBaivo",
  "description": "Remote input sharing over WebRTC",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "signaling": "bun run apps/signaling/server.ts",
    "host": "electron dist/apps/host/main.js",
    "client": "electron dist/apps/client/main.js",
    "build": "tsc -p packages/shared/tsconfig.json && tsc && vite build",
    "build:shared": "tsc -p packages/shared/tsconfig.json",
    "build:main": "tsc",
    "build:ui": "vite build",
    "rebuild": "npx @electron/rebuild -f -w koffi",
    "pack:host": "electron-builder --config apps/host/electron-builder.json",
    "pack:client": "electron-builder --config apps/client/electron-builder.json"
  },
  "dependencies": {
    "koffi": "^2.15.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.3"
  }
}
