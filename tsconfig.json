{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@inputshare/shared": ["./packages/shared/index.ts"],
      "@inputshare/shared/*": ["./packages/shared/*"]
    }
  },
  "include": [
    "packages/shared/**/*.ts",
    "apps/host/**/*.ts",
    "apps/client/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "apps/host/ui",
    "apps/client/ui",
    "apps/signaling"
  ]
}
