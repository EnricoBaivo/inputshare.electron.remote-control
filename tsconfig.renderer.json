{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "apps/client/ui/**/*.tsx",
    "apps/client/ui/**/*.ts",
    "apps/host/ui/**/*.tsx",
    "apps/host/ui/**/*.ts",
    "packages/shared/**/*.ts",
    "packages/ui/**/*.tsx",
    "packages/ui/**/*.ts"
  ]
}
